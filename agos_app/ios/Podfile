# Podfile with Firebase iOS compatibility fixes
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\s*=\s*(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # Fix Firebase/Firestore podspec issues
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Fix for Firebase library issues
    if target.name == 'FirebaseCore'
      target.build_configurations.each do |config|
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
          '$(inherited)',
          'COCOAPODS=1',
          'PB_FIELD_32BIT=1',
          'PB_REPEATED_SOLITARY_MERGE_ONCE=1',
        ]
      end
    end

    # Fix parameter type mismatches in Firebase
    target.build_phases.each do |phase|
      if phase.is_a?(Xcodeproj::Project::Object::PBXSourcesBuildPhase)
        phase.files.each do |pbx_file|
          if pbx_file.real_path.to_s.include?('firebase_core') && pbx_file.real_path.to_s.end_with?('.m')
            # This will handle Objective-C parameter type conflicts
            target.build_settings(config) do |config|
              config.build_settings['OTHER_CFLAGS'] = '$(inherited) -Wno-incompatible-function-pointer-types'
            end
          end
        end
      end
    end
  end

  # Fix for all targets
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '12.0'
      # Suppress parameter type warnings that Firebase causes
      config.build_settings['OTHER_CFLAGS'] = '$(inherited) -Wno-incompatible-function-pointer-types -Wno-incompatible-pointer-types'
      # Suppress deprecation warnings
      config.build_settings['GCC_WARN_SHADOW'] = 'NO'
    end
  end
end
