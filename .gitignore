# ============================================================
# AGOS - Root .gitignore
# ============================================================

# ---- Sensitive / Secret files (NEVER commit these) --------
serviceAccountKey.json
agos-prod-firebase-adminsdk-*.json
agos_app/android/app/google-services.json
agos_app/ios/Runner/GoogleService-Info.plist
.env
*.env
*.key
*.pem

# ---- Python ------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
*.egg

# ---- Flutter / Dart ----------------------------------------
**/doc/api/
**/ios/Flutter/.last_build_id
**/.dart_tool/
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/build/
**/coverage/
*.iml
*.ipr
*.iws

# ---- Android -----------------------------------------------
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/local.properties

# ---- iOS ---------------------------------------------------
**/ios/Pods/
**/ios/.symlinks/

# ---- IDEs --------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Logs --------------------------------------------------
*.log
flutter_log*.txt

# ---- Generated files ---------------------------------------
app.*.symbols
app.*.map.json
