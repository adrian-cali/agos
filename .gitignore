# ============================================================
# AGOS — .gitignore
# ============================================================

# ── Project / IDE ────────────────────────────────────────────
.github/
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS files ─────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ── Environment / Secrets ────────────────────────────────────
.env
.env.local
.env.*.local

# Firebase — NEVER commit these
backend/serviceAccountKey.json
agos_app/android/app/google-services.json
agos_app/ios/Runner/GoogleService-Info.plist

# ── Python / Backend ─────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
pip-wheel-metadata/

# ── Flutter / Dart ───────────────────────────────────────────
agos_app/.dart_tool/
agos_app/.flutter-plugins
agos_app/.flutter-plugins-dependencies
agos_app/.packages
agos_app/build/
agos_app/android/.gradle/
agos_app/android/local.properties
agos_app/android/key.properties
agos_app/ios/.symlinks/
agos_app/ios/Pods/
agos_app/ios/Flutter/flutter_export_environment.sh
agos_app/ios/Flutter/Generated.xcconfig
agos_app/ios/Flutter/ephemeral/
agos_app/macos/Flutter/GeneratedPluginRegistrant.swift
agos_app/macos/Flutter/ephemeral/
agos_app/linux/flutter/generated_plugin_registrant.cc
agos_app/linux/flutter/generated_plugin_registrant.h
agos_app/linux/flutter/generated_plugins.cmake
agos_app/windows/flutter/generated_plugin_registrant.cc
agos_app/windows/flutter/generated_plugin_registrant.h
agos_app/windows/flutter/generated_plugins.cmake
*.g.dart
*.freezed.dart

# ── Build outputs ────────────────────────────────────────────
out/
*.tsbuildinfo

# ── Dependencies ─────────────────────────────────────────────
node_modules/
bower_components/

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
flutter_log.txt
flutter_log2.txt

# ── Internal planning / prompt docs ──────────────────────────
CLAUDE_PROMPT.md
IMPLEMENTATION_GUIDE.md
SYSTEM_PLAN.md

# ── Coverage / Cache / Temp ──────────────────────────────────
coverage/
*.lcov
.cache/
.eslintcache
.stylelintcache
tmp/
temp/
