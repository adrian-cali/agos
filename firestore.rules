rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requester is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // ── Users collection: only the owner can read/write their own doc ──────
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ── Devices collection: owner can read/write their device doc ──────────
    match /devices/{deviceId} {
      allow read: if isAuth() && (
        resource.data.owner_uid == request.auth.uid
      );
      allow write: if isAuth() && (
        request.resource.data.owner_uid == request.auth.uid
      );
    }

    // ── Sensor readings: authenticated users can read their device's readings
    // Backend (Admin SDK) bypasses rules and can always write.
    match /sensor_readings/{readingId} {
      allow read: if isAuth();
      // App cannot write readings directly — only backend writes via Admin SDK
      allow write: if false;
    }

    // ── Pump commands: authenticated users can read (backend writes via Admin SDK)
    match /pump_commands/{cmdId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ── Thresholds and settings: only the owner ────────────────────────────
    match /thresholds/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

  }
}
