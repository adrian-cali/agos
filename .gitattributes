# Normalize line endings to LF in the repository
* text=auto eol=lf

# Binary files ΓÇö no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
*.7z binary
*.gz binary
*.zip binary
*.jar binary
*.apk binary
*.aab binary

# Dart / Flutter
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Python
*.py text eol=lf

# Gradle / Android
*.gradle text eol=lf
*.kts text eol=lf
*.properties text eol=lf

# Scripts ΓÇö force LF on bat/sh
*.sh text eol=lf
*.bat text eol=crlf
